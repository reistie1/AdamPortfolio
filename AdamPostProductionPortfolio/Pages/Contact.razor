@page "/contact"

<PageTitle>Contact</PageTitle>

<div class="min-h-screen w-full bg-neutral-900 text-white">

    <section 
        class="max-w-3xl mx-auto px-6 py-24 space-y-16"
        role="region"
        aria-labelledby="contact-heading">

        <!-- Header -->
        <div class="text-center space-y-4">
            <h1 id="contact-heading" class="text-4xl sm:text-5xl md:text-6xl font-bold">
                Let’s Work Together
            </h1>

            <p class="text-lg sm:text-xl text-gray-300">
                Have a project that needs clean dialogue, immersive sound design, 
                or a polished final mix? I’d love to hear about it.
            </p>
        </div>

        <!-- Disclaimer -->
        <div class="bg-neutral-800 p-4 rounded-lg text-gray-400 leading-relaxed">
            <p>
                I would to love to hear about your project and discuss how I can help. Please ensure that you provide as much detail in the message box below about your project, including the type of content, timeline, deliverables, and any specific audio needs or challenges you are facing. This will help me understand your requirements and provide the best possible service. I look forward to connecting with you and bringing your project to life with high-quality audio post-production. No project is too small!
            </p>
        </div>

        <!-- Contact Info -->
        <div class="space-y-6 text-center">
            <p class="text-gray-300 text-lg">
                Email me at  
                <a href="mailto:adamreist1@gmail.com" 
                   class="text-white underline hover:text-gray-300 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900">
                    adamreist1@gmail.com
                </a>
            </p>

            <p class="text-gray-400">Based in Kitchener, ON — working worldwide</p>

            <nav aria-label="Social links">
                <div class="flex justify-center gap-6 text-gray-300">
                    <a href="#" class="hover:text-white transition focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900">
                        LinkedIn
                    </a>
                    <a href="#" class="hover:text-white transition focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900">
                        Instagram
                    </a>
                    <a href="#" class="hover:text-white transition focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900">
                        SoundCloud
                    </a>
                </div>
            </nav>
        </div>

        <!-- Contact Form -->
        <form class="space-y-6 bg-neutral-800 p-8 rounded-xl shadow-lg" aria-labelledby="form-heading">
            
            <h2 id="form-heading" class="sr-only">Contact Form</h2>

            <div>
                <label for="name" class="block text-gray-300 mb-2">Name</label>
                <input id="name" type="text" 
                       class="w-full px-4 py-3 bg-neutral-700 text-white rounded-lg 
                              focus:outline-none focus:ring-2 focus:ring-blue-500"
                       aria-required="true">
            </div>

            <div>
                <label for="email" class="block text-gray-300 mb-2">Email</label>
                <input id="email" type="email" 
                       class="w-full px-4 py-3 bg-neutral-700 text-white rounded-lg 
                              focus:outline-none focus:ring-2 focus:ring-blue-500"
                       aria-required="true">
            </div>

            <div>
                <label for="message" class="block text-gray-300 mb-2">Message</label>
                <textarea id="message" rows="5"
                          class="w-full px-4 py-3 bg-neutral-700 text-white rounded-lg 
                                 focus:outline-none focus:ring-2 focus:ring-blue-500"
                          aria-required="true"></textarea>
            </div>

            <button 
                class="w-full py-3 rounded-full bg-white/10 text-white backdrop-blur-sm 
                       hover:bg-white/20 transition 
                       focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900"
                aria-label="Send message">
                Send Message
            </button>

        </form>

    </section>

</div>