@page "/services"
@using AdamPostProductionPortfolio.Components

<PageTitle>Services</PageTitle>

<div class="min-h-screen w-full bg-neutral-900 text-white">

    <section 
        class="max-w-5xl mx-auto px-6 py-24 space-y-24"
        role="region"
        aria-labelledby="services-heading">

        <!-- Header -->
        <div class="space-y-4 text-center">
            <h1 id="services-heading" class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight">
                Audio Post‑Production Services
            </h1>

            <p class="text-lg sm:text-xl text-gray-300">
                Clean dialogue. Immersive soundscapes. Broadcast‑ready mixes.
            </p>
        </div>

        <!-- Services Grid -->
        <div 
            class="grid grid-cols-1 md:grid-cols-2 gap-16"
            role="list"
            aria-label="List of audio post-production services">

            <ServicesItem 
                Title="Dialogue Editing"
                Description="Clean, natural, and intelligible dialogue. Removing noise, breaths, clicks, pops, and inconsistencies to ensure every voice is audible and transparent." />

            <ServicesItem 
                Title="Mixing"
                Description="I am actively refining my expertise in audio mixing through hands-on work across film, music, and student productions, with a focus on developing strong technical skills and a creative approach to sound." />

            <ServicesItem 
                Title="Sound Design"
                Description="Ability to craft detailed and unique Backgrounds, Ambiences, Whooshes, Impacts, Textures, and Effects to add dynamics and punch to your project." />

            <ServicesItem 
                Title="Audio Restoration"
                Description="Repairing problematic audio using industry‑leading tools. Noise reduction, de‑reverb, hum removal, and artifact cleanup." />

            <ServicesItem 
                Title="Mastering"
                Description="Final loudness, EQ, and dynamic shaping to ensure your project meets platform standards." />

            <ServicesItem 
                Title="Additional Services"
                Description="Foley editing, podcast editing, ADR cleanup, music editing, deliverables & exports." />

        </div>

        <!-- Workflow -->
        <div class="space-y-6">
            <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">My Workflow</h2>

            <ol class="space-y-4 text-gray-300 leading-relaxed">
                <li>
                    <strong class="text-white">1. Receive & Review</strong> — 
                    You send your project files, notes, and references.
                </li>

                <li>
                    <strong class="text-white">2. Edit & Mix</strong> — 
                    I clean, shape, and build the audio. Through a step by step approach, we will ensure your final project meets your vision.
                </li>

                <li>
                    <strong class="text-white">3. Deliver</strong> — 
                    You receive polished, platform‑ready audio with revisions included. This includes any deliverables specified in the review stage.
                </li>
            </ol>
        </div>

        <!-- CTA -->
        <div class="pt-10 text-center">
            <a href="contact"
               class="px-10 py-4 rounded-full bg-white/10 text-white backdrop-blur-sm 
                      hover:bg-white/20 transition 
                      focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900"
               aria-label="Go to contact page" @onclick="NavigateToContact" @onclick:preventDefault>
                Contact Me
            </a>
        </div>

    </section>

</div>

@code {
    [Inject]
    public NavigationManager Navigation { get; set; }

    private void NavigateToContact()
    {
        Navigation.NavigateTo("contact");
    }
}