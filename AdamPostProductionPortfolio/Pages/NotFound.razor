@page "/not-found"
@layout MainLayout

<div class="flex flex-col items-center justify-center h-screen gap-6">
    <h3>Page Not Found</h3>
    <button
        class="px-10 py-4 rounded-full bg-black/10 text-white backdrop-blur-sm hover:bg-white/20 transition inline-block focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900"
        aria-label="Go to home page" @onclick="NavigateToHome">
        Home
    </button>
</div>

@code {
    [Inject]
    public NavigationManager NavigationManager { get; set; }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo("/");
    }
}