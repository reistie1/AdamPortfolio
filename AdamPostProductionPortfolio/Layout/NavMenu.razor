<div class="bg-black text-white px-6 py-4 border-b border-gray-700">

    <nav class="flex items-center justify-end gap-6"
         role="navigation"
         aria-label="Main navigation">

        <!-- Mobile Toggle Button -->
        <button class="md:hidden p-2 focus:outline-none focus:ring-2 focus:ring-white rounded"
                aria-expanded="@(!collapseNavMenu)"
                aria-label="Toggle navigation menu"
                @onclick="ToggleNavMenu">
            <span class="sr-only">Toggle Menu</span>
        </button>

        <!-- Navigation Links -->
        <div class="@($"md:flex gap-6 {(collapseNavMenu ? "hidden" : "flex flex-col gap-4 mt-4")}")">

            <NavLink href="/" Match="NavLinkMatch.All"
                     class="hover:text-gray-300 transition">
                Home
            </NavLink>

            <NavLink href="/portfolio" Match="NavLinkMatch.Prefix"
                     class="hover:text-gray-300 transition">
                Portfolio
            </NavLink>

            <NavLink href="/about" Match="NavLinkMatch.Prefix"
                     class="hover:text-gray-300 transition">
                About
            </NavLink>

            <NavLink href="/contact" Match="NavLinkMatch.Prefix"
                     class="hover:text-gray-300 transition">
                Contact
            </NavLink>

            <NavLink href="/services" Match="NavLinkMatch.Prefix"
                     class="hover:text-gray-300 transition">
                Services
            </NavLink>

        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}